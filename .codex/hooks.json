{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pabcd_pre_tool_guard.py\"",
            "timeout": 30,
            "statusMessage": "Checking PABCD gate command safety"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pabcd_stop_guard.py\"",
            "timeout": 240,
            "statusMessage": "Checking PABCD gate scope and closeout"
          }
        ]
      }
    ]
  }
}
