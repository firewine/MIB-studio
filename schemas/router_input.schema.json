{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MIB Router Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["text", "allowed_routes"],
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8000
    },
    "allowed_routes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]{1,64}$"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
