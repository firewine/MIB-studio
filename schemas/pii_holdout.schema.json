{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MIB PII Holdout Row",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "locale", "text", "entities", "source"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^pii_[a-z0-9_:-]{1,80}$"
    },
    "locale": {
      "enum": ["ko-KR", "en-US", "mixed"]
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "start", "end", "text"],
        "properties": {
          "type": {
            "enum": ["email", "phone", "rrn", "card", "account", "ip", "name", "address"]
          },
          "start": {
            "type": "integer",
            "minimum": 0
          },
          "end": {
            "type": "integer",
            "minimum": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source": {
      "enum": ["synthetic", "red_team", "regression"]
    },
    "notes": {
      "type": "string"
    }
  }
}
