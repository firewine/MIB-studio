{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MIB Studio",
  "version": "0.1.0",
  "identifier": "studio.mib.desktop",
  "build": {
    "beforeDevCommand": "COREPACK_HOME=/tmp/corepack corepack pnpm dev",
    "beforeBuildCommand": "COREPACK_HOME=/tmp/corepack corepack pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MIB Studio",
        "width": 1360,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  }
}
